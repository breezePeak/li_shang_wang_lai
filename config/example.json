{
  "browser": {
    "headless": false,
    "profileDir": ".playwright/douyin-profile",
    "slowMo": 150
  },
  "comments": {
    "enabled": true,
    "mode": "manual",
    "maxPerRun": 10,
    "maxReplyLength": 400
  },
  "likes": {
    "enabled": true,
    "mode": "manual",
    "allowedRelations": ["friend", "mutual"],
    "maxPerRun": 5,
    "skipPinned": true,
    "requireLatestWorkConfirmed": true
  },
  "returnVisit": {
    "enabled": true,
    "eventSourceStatus": "new",
    "sourceDays": 7,
    "taskEventLimit": 500,
    "prepareMaxItems": 20,
    "executeMaxItems": 20
  },
  "safety": {
    "stopOnLoginRequired": true,
    "stopOnCaptcha": true,
    "captureScreenshotOnAction": true,
    "captureScreenshotOnFailure": true
  }
}
